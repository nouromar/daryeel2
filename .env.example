# Daryeel2 (docker-compose)

# Optional: public base URL for schema-service to advertise in /config/bootstrap
# SCHEMA_SERVICE_PUBLIC_BASE_URL=http://localhost:8011

# Optional: enable Redis-backed caching for schema-service.
# To use with docker compose, start the redis profile and set this URL.
# SCHEMA_SERVICE_REDIS_URL=redis://redis:6379/0

# Optional: override cache key prefix
# SCHEMA_SERVICE_REDIS_KEY_PREFIX=daryeel2:schema-service:
