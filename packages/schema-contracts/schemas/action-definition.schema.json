{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "daryeel2/schema-contracts/action-definition.schema.json",
  "title": "ActionDefinition",
  "type": "object",
  "required": ["type"],
  "properties": {
    "type": {
      "type": "string",
      "minLength": 1
    },
    "route": { "type": "string" },
    "formId": { "type": "string" },
    "modalId": { "type": "string" },
    "dataSource": { "type": "string" },
    "value": {},
    "eventName": { "type": "string" },
    "eventProperties": {
      "type": "object",
      "additionalProperties": {
        "type": ["string", "number", "boolean"]
      }
    }
  },
  "additionalProperties": false
}