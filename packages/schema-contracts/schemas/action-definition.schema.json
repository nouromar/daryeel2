{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "daryeel2/schema-contracts/action-definition.schema.json",
  "title": "ActionDefinition",
  "type": "object",
  "required": ["type"],
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "navigate",
        "open_url",
        "set_state",
        "patch_state",
        "submit_form",
        "track_event",
        "open_modal",
        "refresh_data",
        "select_value",
        "dismiss"
      ]
    },
    "route": { "type": "string" },
    "formId": { "type": "string" },
    "modalId": { "type": "string" },
    "dataSource": { "type": "string" },
    "value": {},
    "eventName": { "type": "string" },
    "eventProperties": {
      "type": "object",
      "additionalProperties": {
        "type": ["string", "number", "boolean"]
      }
    }
  },
  "additionalProperties": false
}