{
  "name": "ActionCard",
  "category": "action",
  "version": "1.0",
  "propsSchema": {
    "title": "string",
    "subtitle": "string",
    "surface": "enum",
    "icon": "string",
    "density": "enum",
    "titleVariant": "enum",
    "titleWeight": "enum",
    "titleColor": "enum",
    "subtitleVariant": "enum",
    "subtitleWeight": "enum",
    "subtitleColor": "enum"
  },
  "defaults": {
    "surface": "raised",
    "density": "comfortable"
  },
  "styleContract": {
    "surface": ["raised", "flat", "subtle"],
    "density": ["compact", "comfortable"],
    "titleVariant": ["body", "label", "caption", "subtitle", "title"],
    "titleWeight": ["regular", "medium", "semibold", "bold"],
    "titleColor": ["default", "muted", "primary", "secondary", "error"],
    "subtitleVariant": ["body", "label", "caption", "subtitle", "title"],
    "subtitleWeight": ["regular", "medium", "semibold", "bold"],
    "subtitleColor": ["default", "muted", "primary", "secondary", "error"]
  },
  "slots": [],
  "events": ["tap"],
  "actions": ["tap"],
  "fallbackBehavior": "omit"
}
