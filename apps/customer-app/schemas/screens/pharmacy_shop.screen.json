{
  "schemaVersion": "1.0",
  "id": "pharmacy_shop",
  "documentType": "screen",
  "product": "customer_app",
  "themeId": "customer-default",
  "themeMode": "light",
  "root": {
    "type": "ScreenTemplate",
    "slots": {
      "body": [
        {
          "type": "Column",
          "props": {
            "spacing": 8,
            "crossAxisAlignment": "stretch",
            "mainAxisSize": "min"
          },
          "slots": {
            "children": [
              {
                "type": "TextInput",
                "props": {
                  "label": "Search Product",
                  "hint": "Search Product",
                  "testId": "pharmacy_search"
                },
                "bind": "pharmacy_catalog.q"
              },
              {
                "type": "Align",
                "props": { "alignment": "centerRight" },
                "slots": {
                  "child": [
                    {
                      "type": "SizedBox",
                      "props": { "width": 240 },
                      "slots": {
                        "child": [
                          {
                            "type": "ActionCard",
                            "props": {
                              "title": "Attach Prescription",
                              "subtitle": "",
                              "surface": "flat"
                            },
                            "actions": { "tap": "go_prescription_upload" }
                          }
                        ]
                      }
                    }
                  ]
                }
              }
            ]
          }
        },
        {
          "type": "RemotePagedList",
          "props": {
            "key": "pharmacy_catalog",
            "path": "/v1/pharmacy/catalog",
            "params": {
              "q": "$form.pharmacy_catalog.q",
              "limit": "20"
            },
            "itemsPath": "items",
            "nextCursorPath": "next.cursor",
            "cursorParam": "cursor",
            "itemKeyPath": "id"
          },
          "slots": {
            "error": [
              {
                "type": "InfoCard",
                "props": {
                  "title": "Could not load catalog",
                  "subtitle": "Please try again",
                  "surface": "raised"
                }
              }
            ],
            "empty": [
              {
                "type": "InfoCard",
                "props": {
                  "title": "No products",
                  "subtitle": "Try a different search",
                  "surface": "subtle"
                }
              }
            ],
            "item": [
              {
                "type": "Padding",
                "props": { "bottom": 8 },
                "slots": {
                  "child": [
                    {
                      "type": "CatalogItemTile",
                      "props": {
                        "titlePath": "name",
                        "subtitlePath": "subtitle",
                        "rxRequiredPath": "rx_required"
                      },
                      "actions": { "add": "pharmacy_add_to_cart" }
                    }
                  ]
                }
              }
            ]
          }
        }
      ]
    }
  },
  "actions": {
    "pharmacy_add_to_cart": {
      "type": "pharmacy_cart_upsert",
      "value": {
        "id": "${item.id}",
        "name": "${item.name}",
        "subtitle": "${item.subtitle}",
        "rx_required": "${item.rx_required}",
        "price": "${item.price}",
        "icon": "${item.icon}",
        "route": "${item.route}"
      }
    },
    "go_prescription_upload": {
      "type": "navigate",
      "route": "customer.schema_sheet",
      "value": {
        "screenId": "pharmacy_prescription_upload",
        "title": "Attach Prescription",
        "chromePreset": "pharmacy_cart_badge"
      }
    }
  }
}
