{
  "schemaVersion": "1.0",
  "id": "pharmacy_checkout",
  "documentType": "screen",
  "product": "customer_app",
  "themeId": "customer-default",
  "themeMode": "light",
  "root": {
    "type": "ScreenTemplate",
    "slots": {
      "body": [
        {
          "type": "Column",
          "props": {
            "spacing": 12,
            "crossAxisAlignment": "stretch",
            "mainAxisSize": "min"
          },
          "slots": {
            "children": [
              {
                "type": "AddressSection",
                "props": {
                  "title": "Delivery address",
                  "variant": "default",
                  "sources": {
                    "defaultAddress": true,
                    "currentLocation": true,
                    "providerAutocomplete": false,
                    "savedPlaces": true,
                    "recents": true,
                    "manualEntry": true,
                    "mapPin": true
                  }
                },
                "bind": "$state.pharmacy.cart.deliveryAddress"
              },
              { "type": "PharmacyCheckout" }
            ]
          }
        }
      ],
      "footer": [
        {
          "type": "PrimaryActionBar",
          "props": { "primaryLabel": "Submit order", "expand": true },
          "actions": { "primary": "submit" }
        }
      ]
    }
  },
  "actions": {
    "submit": { "type": "submit_form", "formId": "pharmacy_checkout" }
  }
}
