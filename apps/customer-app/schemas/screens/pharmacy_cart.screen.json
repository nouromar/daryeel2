{
  "schemaVersion": "1.0",
  "id": "pharmacy_cart",
  "documentType": "screen",
  "product": "customer_app",
  "themeId": "customer-default",
  "themeMode": "light",
  "root": {
    "type": "ScreenTemplate",
    "props": {
      "headerGap": 8,
      "bodyPadding": { "all": 16 },
      "primaryScrollPadding": { "horizontal": 16 },
      "footerPadding": { "left": 16, "top": 0, "right": 16, "bottom": 16 },
      "stateDefaults": {
        "pharmacy.cart.lines": [],
        "pharmacy.cart.totalQuantity": 0,
        "pharmacy.cart.hasRxItem": false,
        "pharmacy.cart.rxItemCount": 0,
        "pharmacy.cart.prescriptionUploads": [],
        "pharmacy.cart.subtotal": 0,
        "pharmacy.cart.tax": 0,
        "pharmacy.cart.discount": 0,
        "pharmacy.cart.summary.lines": [],
        "pharmacy.cart.summary.total": {
          "label": "Total",
          "amount": 0,
          "amountText": "$0.00",
          "kind": "total",
          "emphasis": "strong"
        },
        "pharmacy.cart.summary.isRefreshing": false,
        "pharmacy.cart.summary.lastUpdatedAt": ""
      }
    },
    "slots": {
      "body": [
        {
          "type": "InfoCard",
          "visibleWhen": {
            "expr": "len(state.pharmacy.cart.lines) == 0 and len(state.pharmacy.cart.prescriptionUploads) == 0"
          },
          "props": {
            "title": "Danbiishu Waa Faaruq",
            "subtitle": "Ku dar alaabo si aad u aragto halkan.",
            "surface": "subtle"
          }
        },
        {
          "type": "Column",
          "visibleWhen": {
            "expr": "len(state.pharmacy.cart.lines) > 0"
          },
          "props": {
            "spacing": 14,
            "crossAxisAlignment": "stretch",
            "mainAxisSize": "min"
          },
          "slots": {
            "children": [
              {
                "type": "ForEach",
                "props": {
                  "itemsPath": "$state.pharmacy.cart.lines",
                  "itemKeyPath": "id"
                },
                "slots": {
                  "item": [
                    {
                      "type": "CartItem",
                      "props": {
                        "title": "${item.name}",
                        "subtitle": "${item.subtitle}",
                        "quantity": "${item.quantity}",
                        "unitPriceText": "$${item.price}",
                        "rxRequired": "${item.rx_required}",
                        "surface": "raised"
                      },
                      "actions": {
                        "increment": "pharmacy_cart_increment",
                        "decrement": "pharmacy_cart_decrement"
                      }
                    }
                  ]
                }
              }
            ]
          }
        },
        {
          "type": "Gap",
          "visibleWhen": {
            "expr": "len(state.pharmacy.cart.lines) > 0"
          },
          "props": { "height": 8 }
        },
        {
          "type": "CartSummary",
          "visibleWhen": {
            "expr": "len(state.pharmacy.cart.lines) > 0"
          },
          "props": {
            "title": "Order summary",
            "linesPath": "$state.pharmacy.cart.summary.lines",
            "totalPath": "$state.pharmacy.cart.summary.total",
            "surface": "raised"
          }
        },
        {
          "type": "Gap",
          "visibleWhen": {
            "expr": "(state.pharmacy.cart.hasRxItem == true and len(state.pharmacy.cart.prescriptionUploads) == 0) or len(state.pharmacy.cart.prescriptionUploads) > 0"
          },
          "props": { "height": 12 }
        },
        {
          "type": "TextButton",
          "visibleWhen": {
            "expr": "state.pharmacy.cart.hasRxItem == true and len(state.pharmacy.cart.prescriptionUploads) == 0"
          },
          "props": {
            "label": "Attach Prescription",
            "align": "right"
          },
          "actions": { "tap": "go_prescription_upload" }
        },
        {
          "type": "ActionCard",
          "visibleWhen": {
            "expr": "len(state.pharmacy.cart.prescriptionUploads) > 0"
          },
          "props": {
            "title": "Prescription attached",
            "subtitle": "",
            "surface": "flat"
          },
          "actions": { "tap": "go_prescription_upload" }
        },
        {
          "type": "ForEach",
          "visibleWhen": {
            "expr": "len(state.pharmacy.cart.prescriptionUploads) > 0"
          },
          "props": {
            "itemsPath": "$state.pharmacy.cart.prescriptionUploads"
          },
          "slots": {
            "item": [
              {
                "type": "Padding",
                "props": {
                  "bottom": 6
                },
                "slots": {
                  "child": [
                    {
                      "type": "Row",
                      "props": {
                        "crossAxisAlignment": "center",
                        "spacing": 12
                      },
                      "slots": {
                        "children": [
                          {
                            "type": "Expanded",
                            "slots": {
                              "child": [
                                {
                                  "type": "Text",
                                  "props": {
                                    "text": "${item.filename}",
                                    "variant": "caption",
                                    "color": "muted",
                                    "maxLines": 1,
                                    "overflow": "ellipsis"
                                  }
                                }
                              ]
                            }
                          },
                          {
                            "type": "TapArea",
                            "props": {
                              "minSize": 0,
                              "semanticLabel": "Delete prescription"
                            },
                            "slots": {
                              "child": [
                                {
                                  "type": "Icon",
                                  "props": {
                                    "name": "delete",
                                    "size": 18,
                                    "color": "muted"
                                  }
                                }
                              ]
                            },
                            "actions": { "tap": "remove_upload" }
                          }
                        ]
                      }
                    }
                  ]
                }
              }
            ]
          }
        },
        {
          "type": "Gap",
          "visibleWhen": {
            "expr": "len(state.pharmacy.cart.lines) > 0"
          },
          "props": { "height": 12 }
        },
        {
          "type": "PrimaryActionBar",
          "visibleWhen": {
            "expr": "len(state.pharmacy.cart.lines) > 0"
          },
          "props": { "primaryLabel": "Checkout", "expand": true },
          "actions": { "primary": "go_checkout" }
        },
        {
          "type": "Gap",
          "visibleWhen": {
            "expr": "len(state.pharmacy.cart.lines) > 0"
          },
          "props": { "height": 8 }
        },
        {
          "type": "TextButton",
          "visibleWhen": {
            "expr": "len(state.pharmacy.cart.lines) > 0"
          },
          "props": { "label": "Clear cart", "align": "right" },
          "actions": { "tap": "pharmacy_cart_clear" }
        }
      ]
    }
  },
  "actions": {
    "pharmacy_cart_increment": {
      "type": "pharmacy_cart_increment",
      "value": { "id": "${item.id}" }
    },
    "pharmacy_cart_decrement": {
      "type": "pharmacy_cart_decrement",
      "value": { "id": "${item.id}" }
    },
    "pharmacy_cart_clear": {
      "type": "pharmacy_cart_clear"
    },
    "go_prescription_upload": {
      "type": "navigate",
      "route": "customer.schema_sheet",
      "value": {
        "screenId": "pharmacy_prescription_upload",
        "title": "Attach Prescription",
        "chromePreset": "pharmacy_cart_badge"
      }
    },
    "go_checkout": {
      "type": "navigate",
      "route": "customer.schema_screen",
      "value": {
        "screenId": "pharmacy_checkout",
        "title": "Checkout"
      }
    },
    "remove_upload": {
      "type": "patch_state",
      "value": {
        "ops": [
          {
            "op": "remove",
            "path": "pharmacy.cart.prescriptionUploads.${index}"
          }
        ]
      }
    }
  }
}
