{
  "schemaVersion": "1.0",
  "id": "customer_request_detail",
  "documentType": "screen",
  "product": "customer_app",
  "themeId": "customer-default",
  "themeMode": "light",
  "root": {
    "type": "ScreenTemplate",
    "props": {
      "headerGap": 8,
      "bodyPadding": { "all": 16 },
      "primaryScrollPadding": { "horizontal": 16 },
      "footerPadding": { "left": 16, "top": 0, "right": 16, "bottom": 16 }
    },
    "slots": {
      "body": [
        {
          "type": "RemoteQuery",
          "props": {
            "key": "customer.request_detail",
            "path": "/v1/requests/detail",
            "params": {
              "requestId": "$route.requestId"
            }
          },
          "slots": {
            "loading": [
              {
                "type": "InfoCard",
                "props": {
                  "title": "Request",
                  "subtitle": "Loading details...",
                  "density": "compact",
                  "titleVariant": "title",
                  "titleWeight": "bold",
                  "subtitleVariant": "body",
                  "subtitleColor": "muted",
                  "surface": "subtle"
                }
              }
            ],
            "error": [
              {
                "type": "InfoCard",
                "props": {
                  "title": "Request",
                  "subtitle": "Could not load request details.",
                  "density": "compact",
                  "titleVariant": "title",
                  "titleWeight": "bold",
                  "subtitleVariant": "body",
                  "subtitleColor": "muted",
                  "surface": "subtle"
                }
              }
            ],
            "child": [
              {
                "type": "Column",
                "props": {
                  "spacing": 12,
                  "crossAxisAlignment": "stretch",
                  "mainAxisSize": "min"
                },
                "slots": {
                  "children": [
                    {
                      "type": "InfoCard",
                      "visibleWhen": {
                        "expr": "data.request.detailSubtitle != null and data.request.detailSubtitle != ''"
                      },
                      "props": {
                        "title": "${data.request.title}",
                        "subtitle": "${data.request.detailSubtitle}",
                        "variant": "compact",
                        "density": "compact",
                        "titleVariant": "title",
                        "titleWeight": "bold",
                        "subtitleVariant": "body",
                        "subtitleColor": "muted",
                        "surface": "flat"
                      }
                    },
                    {
                      "type": "InfoCard",
                      "visibleWhen": {
                        "expr": "data.request.detailSubtitle == null or data.request.detailSubtitle == ''"
                      },
                      "props": {
                        "title": "${data.request.title}",
                        "subtitle": "${data.request.subtitle}",
                        "variant": "compact",
                        "density": "compact",
                        "titleVariant": "title",
                        "titleWeight": "bold",
                        "subtitleVariant": "body",
                        "subtitleColor": "muted",
                        "surface": "flat"
                      }
                    },
                    {
                      "type": "InfoCard",
                      "visibleWhen": {
                        "expr": "data.request.isAttentionRequired == true or data.request.isUpdateAvailable == true"
                      },
                      "props": {
                        "title": "${data.request.attentionTitle}",
                        "subtitle": "${data.request.attentionSubtitle}",
                        "variant": "emphasized",
                        "density": "compact",
                        "titleVariant": "title",
                        "titleWeight": "bold",
                        "subtitleVariant": "body",
                        "surface": "subtle"
                      }
                    },
                    {
                      "type": "Column",
                      "visibleWhen": {
                        "expr": "data.request.pendingActionCount != null and data.request.pendingActionCount > 0 and pendingActions != null and pendingActions.length > 0"
                      },
                      "props": {
                        "spacing": 8,
                        "crossAxisAlignment": "stretch",
                        "mainAxisSize": "min"
                      },
                      "slots": {
                        "children": [
                          {
                            "type": "Padding",
                            "props": { "left": 20 },
                            "slots": {
                              "child": [
                                {
                                  "type": "Text",
                                  "props": {
                                    "text": "Pending actions",
                                    "variant": "subtitle",
                                    "weight": "semibold",
                                    "color": "secondary"
                                  }
                                }
                              ]
                            }
                          },
                          {
                            "type": "ForEach",
                            "props": {
                              "itemsPath": "pendingActions"
                            },
                            "slots": {
                              "item": [
                                {
                                  "type": "InfoCard",
                                  "props": {
                                    "title": "${item.title}",
                                    "subtitle": "${item.subtitle}",
                                    "density": "compact",
                                    "titleVariant": "title",
                                    "titleWeight": "semibold",
                                    "subtitleVariant": "body",
                                    "subtitleColor": "muted",
                                    "surface": "flat"
                                  }
                                },
                                {
                                  "type": "Padding",
                                  "visibleWhen": {
                                    "expr": "item.type == 'confirm_price' or item.type == 'confirm_substitution'"
                                  },
                                  "props": { "left": 20 },
                                  "slots": {
                                    "child": [
                                      {
                                        "type": "Row",
                                        "props": {
                                          "spacing": 12,
                                          "crossAxisAlignment": "center"
                                        },
                                        "slots": {
                                          "children": [
                                            {
                                              "type": "TextButton",
                                              "props": {
                                                "label": "Approve"
                                              },
                                              "actions": {
                                                "tap": "approve_pending_action"
                                              }
                                            },
                                            {
                                              "type": "TextButton",
                                              "props": {
                                                "label": "Reject"
                                              },
                                              "actions": {
                                                "tap": "reject_pending_action"
                                              }
                                            }
                                          ]
                                        }
                                      }
                                    ]
                                  }
                                },
                                {
                                  "type": "Padding",
                                  "visibleWhen": {
                                    "expr": "item.type == 'upload_document'"
                                  },
                                  "props": { "left": 20 },
                                  "slots": {
                                    "child": [
                                      {
                                        "type": "TextButton",
                                        "props": {
                                          "label": "Upload now"
                                        },
                                        "actions": {
                                          "tap": "open_upload_pending_action"
                                        }
                                      }
                                    ]
                                  }
                                },
                                {
                                  "type": "Gap",
                                  "visibleWhen": {
                                    "expr": "pendingActions != null and index < pendingActions.length - 1"
                                  },
                                  "props": { "height": 8 }
                                }
                              ]
                            }
                          }
                        ]
                      }
                    },
                    {
                      "type": "Column",
                      "visibleWhen": {
                        "expr": "data.request.deliveryLocation.text != null and data.request.deliveryLocation.text != ''"
                      },
                      "props": {
                        "spacing": 6,
                        "crossAxisAlignment": "stretch",
                        "mainAxisSize": "min"
                      },
                      "slots": {
                        "children": [
                          {
                            "type": "Padding",
                            "props": { "left": 20 },
                            "slots": {
                              "child": [
                                {
                                  "type": "Text",
                                  "props": {
                                    "text": "Delivery Address",
                                    "variant": "subtitle",
                                    "weight": "semibold",
                                    "color": "secondary"
                                  }
                                }
                              ]
                            }
                          },
                          {
                            "type": "InfoCard",
                            "props": {
                              "title": "",
                              "subtitle": "${data.request.deliveryLocation.text}",
                              "variant": "compact",
                              "density": "compact",
                              "subtitleVariant": "body",
                              "subtitleColor": "muted",
                              "surface": "subtle"
                            }
                          }
                        ]
                      }
                    },
                    {
                      "type": "Column",
                      "visibleWhen": {
                        "expr": "data.request.notes != null and data.request.notes != ''"
                      },
                      "props": {
                        "spacing": 6,
                        "crossAxisAlignment": "stretch",
                        "mainAxisSize": "min"
                      },
                      "slots": {
                        "children": [
                          {
                            "type": "Padding",
                            "props": { "left": 20 },
                            "slots": {
                              "child": [
                                {
                                  "type": "Text",
                                  "props": {
                                    "text": "Notes",
                                    "variant": "subtitle",
                                    "weight": "semibold",
                                    "color": "secondary"
                                  }
                                }
                              ]
                            }
                          },
                          {
                            "type": "InfoCard",
                            "props": {
                              "title": "",
                              "subtitle": "${data.request.notes}",
                              "variant": "compact",
                              "density": "compact",
                              "subtitleVariant": "body",
                              "subtitleColor": "muted",
                              "surface": "subtle"
                            }
                          }
                        ]
                      }
                    },
                    {
                      "type": "If",
                      "props": {
                        "valuePath": "serviceDetails.isPharmacy",
                        "op": "isTrue"
                      },
                      "slots": {
                        "then": [
                          {
                            "ref": "fragment:request_detail_pharmacy_v1"
                          }
                        ]
                      }
                    },
                    {
                      "type": "Column",
                      "visibleWhen": {
                        "expr": "data.request.paymentSummaryText != null and data.request.paymentSummaryText != ''"
                      },
                      "props": {
                        "spacing": 6,
                        "crossAxisAlignment": "stretch",
                        "mainAxisSize": "min"
                      },
                      "slots": {
                        "children": [
                          {
                            "type": "Padding",
                            "props": { "left": 20 },
                            "slots": {
                              "child": [
                                {
                                  "type": "Text",
                                  "props": {
                                    "text": "Payment",
                                    "variant": "subtitle",
                                    "weight": "semibold",
                                    "color": "secondary"
                                  }
                                }
                              ]
                            }
                          },
                          {
                            "type": "InfoCard",
                            "props": {
                              "title": "",
                              "subtitle": "${data.request.paymentSummaryText}",
                              "variant": "compact",
                              "density": "compact",
                              "subtitleVariant": "body",
                              "subtitleColor": "muted",
                              "surface": "subtle"
                            }
                          }
                        ]
                      }
                    },
                    {
                      "type": "Column",
                      "visibleWhen": {
                        "valuePath": "timeline",
                        "op": "isNotEmpty"
                      },
                      "props": {
                        "spacing": 8,
                        "crossAxisAlignment": "stretch",
                        "mainAxisSize": "min"
                      },
                      "slots": {
                        "children": [
                          {
                            "type": "Padding",
                            "props": { "left": 20 },
                            "slots": {
                              "child": [
                                {
                                  "type": "Text",
                                  "props": {
                                    "text": "Timeline",
                                    "variant": "subtitle",
                                    "weight": "semibold",
                                    "color": "secondary"
                                  }
                                }
                              ]
                            }
                          },
                          {
                            "type": "ForEach",
                            "props": {
                              "itemsPath": "timeline"
                            },
                            "slots": {
                              "item": [
                                {
                                  "type": "Padding",
                                  "props": { "left": 20 },
                                  "slots": {
                                    "child": [
                                      {
                                        "type": "Row",
                                        "props": {
                                          "mainAxisAlignment": "spaceBetween",
                                          "crossAxisAlignment": "center",
                                          "spacing": 12
                                        },
                                        "slots": {
                                          "children": [
                                            {
                                              "type": "Text",
                                              "props": {
                                                "text": "${item.subtitle}",
                                                "variant": "caption",
                                                "weight": "medium",
                                                "color": "muted",
                                                "maxLines": 1,
                                                "overflow": "clip"
                                              }
                                            },
                                            {
                                              "type": "Text",
                                              "props": {
                                                "text": "${item.title}",
                                                "variant": "body",
                                                "weight": "semibold",
                                                "maxLines": 1,
                                                "overflow": "clip"
                                              }
                                            }
                                          ]
                                        }
                                      }
                                    ]
                                  }
                                },
                                {
                                  "type": "Gap",
                                  "visibleWhen": {
                                    "expr": "timeline != null and index < timeline.length - 1"
                                  },
                                  "props": { "height": 8 }
                                }
                              ]
                            }
                          }
                        ]
                      }
                    }
                  ]
                }
              }
            ]
          }
        }
      ]
    }
  },
  "actions": {
    "approve_pending_action": {
      "type": "customer_request_action",
      "value": {
        "mode": "submit",
        "requestId": "${data.request.id}",
        "actionId": "${item.id}",
        "decision": "approve"
      }
    },
    "reject_pending_action": {
      "type": "customer_request_action",
      "value": {
        "mode": "submit",
        "requestId": "${data.request.id}",
        "actionId": "${item.id}",
        "decision": "reject"
      }
    },
    "open_upload_pending_action": {
      "type": "customer_request_action",
      "value": {
        "mode": "navigate_upload",
        "requestId": "${data.request.id}",
        "actionId": "${item.id}",
        "screenId": "pharmacy_prescription_upload",
        "title": "Upload prescription"
      }
    }
  }
}