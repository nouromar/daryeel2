{
  "schemaVersion": "1.0",
  "id": "customer_request_detail",
  "documentType": "screen",
  "product": "customer_app",
  "themeId": "custome-black-white-clear",
  "themeMode": "light",
  "root": {
    "type": "ScreenTemplate",
    "props": {
      "headerGap": 8,
      "bodyPadding": { "all": 16 },
      "primaryScrollPadding": { "horizontal": 16 },
      "footerPadding": { "left": 16, "top": 0, "right": 16, "bottom": 16 }
    },
    "slots": {
      "body": [
        {
          "type": "RemoteQuery",
          "props": {
            "key": "customer.request_detail",
            "path": "/v1/requests/detail",
            "params": {
              "requestId": "$route.requestId"
            }
          },
          "slots": {
            "loading": [
              {
                "type": "InfoCard",
                "props": {
                  "title": "Request",
                  "subtitle": "Loading details...",
                  "density": "compact",
                  "titleVariant": "title",
                  "titleWeight": "bold",
                  "subtitleVariant": "body",
                  "subtitleColor": "muted",
                  "surface": "subtle"
                }
              }
            ],
            "error": [
              {
                "type": "InfoCard",
                "props": {
                  "title": "Request",
                  "subtitle": "Could not load request details.",
                  "density": "compact",
                  "titleVariant": "title",
                  "titleWeight": "bold",
                  "subtitleVariant": "body",
                  "subtitleColor": "muted",
                  "surface": "subtle"
                }
              }
            ],
            "child": [
              {
                "type": "Column",
                "props": {
                  "spacing": 8,
                  "crossAxisAlignment": "stretch",
                  "mainAxisSize": "min"
                },
                "slots": {
                  "children": [
                    {
                      "type": "InfoCard",
                      "props": {
                        "title": "${data.request.title}",
                        "subtitle": "${isNotBlank(data.request.detailSubtitle) ? data.request.detailSubtitle : data.request.subtitle}",
                        "variant": "compact",
                        "density": "compact",
                        "titleVariant": "title",
                        "titleWeight": "bold",
                        "subtitleVariant": "body",
                        "subtitleColor": "muted",
                        "surface": "flat"
                      }
                    },
                    {
                      "type": "InfoCard",
                      "visibleWhen": {
                        "expr": "isNotBlank(data.request.deliveryLocation.text)"
                      },
                      "props": {
                        "title": "Delivery Address",
                        "subtitle": "${data.request.deliveryLocation.text}",
                        "variant": "compact",
                        "density": "compact",
                        "titleVariant": "subtitle",
                        "titleWeight": "semibold",
                        "titleColor": "secondary",
                        "subtitleVariant": "body",
                        "subtitleColor": "muted",
                        "surface": "subtle"
                      }
                    },
                    {
                      "type": "Column",
                      "visibleWhen": {
                        "expr": "isNotBlank(data.request.notes)"
                      },
                      "props": {
                        "spacing": 6,
                        "crossAxisAlignment": "stretch",
                        "mainAxisSize": "min"
                      },
                      "slots": {
                        "children": [
                          {
                            "type": "Padding",
                            "props": { "left": 20 },
                            "slots": {
                              "child": [
                                {
                                  "type": "Text",
                                  "props": {
                                    "text": "Notes",
                                    "variant": "title",
                                    "weight": "semibold",
                                    "color": "secondary"
                                  }
                                }
                              ]
                            }
                          },
                          {
                            "type": "InfoCard",
                            "props": {
                              "title": "",
                              "subtitle": "${data.request.notes}",
                              "variant": "compact",
                              "density": "compact",
                              "subtitleVariant": "body",
                              "subtitleColor": "muted",
                              "surface": "subtle"
                            }
                          }
                        ]
                      }
                    },
                    {
                      "type": "If",
                      "props": {
                        "expr": "serviceDetails.isPharmacy == true"
                      },
                      "slots": {
                        "then": [
                          {
                            "ref": "fragment:request_detail_pharmacy_v1"
                          }
                        ]
                      }
                    },
                    {
                      "type": "InfoCard",
                      "visibleWhen": {
                        "expr": "isNotBlank(data.request.paymentSummaryText)"
                      },
                      "props": {
                        "title": "Payment",
                        "subtitle": "${data.request.paymentSummaryText}",
                        "variant": "compact",
                        "density": "compact",
                        "titleVariant": "subtitle",
                        "titleWeight": "semibold",
                        "titleColor": "secondary",
                        "subtitleVariant": "body",
                        "subtitleColor": "muted",
                        "surface": "subtle"
                      }
                    },
                    {
                      "type": "Padding",
                      "visibleWhen": {
                        "expr": "len(timeline) > 0"
                      },
                      "props": { "left": 20 },
                      "slots": {
                        "child": [
                          {
                            "type": "Text",
                            "props": {
                              "text": "Timeline",
                              "variant": "title",
                              "weight": "semibold",
                              "color": "secondary"
                            }
                          }
                        ]
                      }
                    },
                    {
                      "type": "Gap",
                      "visibleWhen": {
                        "expr": "len(timeline) > 0"
                      },
                      "props": { "height": 4 }
                    },
                    {
                      "type": "StatusTimelinePanel",
                      "visibleWhen": {
                        "expr": "len(timeline) > 0"
                      },
                      "props": {
                        "title": "",
                        "itemsPath": "timeline",
                        "paddingLeft": 20,
                        "itemGap": 8,
                        "rowSpacing": 12,
                        "titleKey": "title",
                        "subtitleKey": "createdAt",
                        "dateFormat": "dd/MM/yyyy hh:mm a",
                        "itemKeyPath": "id"
                      }
                    }
                  ]
                }
              }
            ]
          }
        }
      ]
    }
  }
}