{
  "schemaVersion": "1.0",
  "documentType": "screen",
  "id": "customer_service_detail",
  "product": "customer_app",
  "themeId": "customer-default",
  "themeMode": "light",
  "root": {
    "type": "ScreenTemplate",
    "slots": {
      "body": [
        {
          "type": "RemoteQuery",
          "props": {
            "key": "service_detail",
            "path": "/v1/service-definitions/detail",
            "dataPath": "items",
            "params": {
              "id": "$route.id"
            }
          },
          "slots": {
            "loading": [
              {
                "type": "InfoCard",
                "props": {
                  "title": "Loading…",
                  "subtitle": "Fetching service"
                }
              }
            ],
            "error": [
              {
                "type": "InfoCard",
                "props": {
                  "title": "Unable to load",
                  "subtitle": "Please try again"
                }
              }
            ],
            "empty": [
              {
                "type": "InfoCard",
                "props": {
                  "title": "Not found",
                  "subtitle": "No service available"
                }
              }
            ],
            "child": [
              {
                "type": "ForEach",
                "slots": {
                  "item": [
                    {
                      "type": "BoundActionCard",
                      "props": {
                        "titlePath": "title",
                        "subtitlePath": "subtitle",
                        "iconPath": "icon",
                        "routePath": "route",
                        "surface": "raised"
                      }
                    },
                    {
                      "type": "Gap",
                      "props": {
                        "height": 12
                      }
                    }
                  ]
                }
              }
            ]
          }
        }
      ]
    }
  },
  "actions": {}
}
