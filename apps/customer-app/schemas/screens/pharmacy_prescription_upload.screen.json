{
  "schemaVersion": "1.0",
  "id": "pharmacy_prescription_upload",
  "documentType": "screen",
  "product": "customer_app",
  "themeId": "customer-default",
  "themeMode": "light",
  "root": {
    "type": "ScreenTemplate",
    "props": {
      "headerGap": 8,
      "bodyPadding": { "all": 16 },
      "primaryScrollPadding": { "horizontal": 16 },
      "footerPadding": { "left": 16, "top": 0, "right": 16, "bottom": 16 }
    },
    "slots": {
      "body": [
        {
          "type": "Column",
          "props": {
            "spacing": 12,
            "crossAxisAlignment": "stretch",
            "mainAxisSize": "min"
          },
          "slots": {
            "children": [
              { "type": "PharmacyPrescriptionUpload" },
              {
                "type": "If",
                "props": {
                  "valuePath": "$state.pharmacy.cart.prescriptionUploads",
                  "op": "isNotEmpty"
                },
                "slots": {
                  "then": [
                    {
                      "type": "Text",
                      "props": {
                        "text": "Uploaded prescriptions",
                        "variant": "title",
                        "weight": "semibold"
                      }
                    },
                    {
                      "type": "ForEach",
                      "props": {
                        "itemsPath": "$state.pharmacy.cart.prescriptionUploads"
                      },
                      "slots": {
                        "item": [
                          {
                            "type": "Padding",
                            "props": { "bottom": 6 },
                            "slots": {
                              "child": [
                                {
                                  "type": "Row",
                                  "props": {
                                    "crossAxisAlignment": "center",
                                    "spacing": 12
                                  },
                                  "slots": {
                                    "children": [
                                      {
                                        "type": "Expanded",
                                        "slots": {
                                          "child": [
                                            {
                                              "type": "Text",
                                              "props": {
                                                "text": "${item.filename}",
                                                "variant": "body",
                                                "maxLines": 1,
                                                "overflow": "ellipsis"
                                              }
                                            }
                                          ]
                                        }
                                      },
                                      {
                                        "type": "IconButton",
                                        "props": {
                                          "name": "delete",
                                          "size": 18,
                                          "color": "muted",
                                          "semanticLabel": "Delete"
                                        },
                                        "actions": {
                                          "tap": "remove_upload"
                                        }
                                      }
                                    ]
                                  }
                                }
                              ]
                            }
                          }
                        ]
                      }
                    }
                  ]
                }
              }
            ]
          }
        }
      ]
    }
  },
  "actions": {
    "remove_upload": {
      "type": "patch_state",
      "value": {
        "ops": [
          {
            "op": "remove",
            "path": "pharmacy.cart.prescriptionUploads.${index}"
          },
          {
            "op": "remove",
            "path": "pharmacy.cart.prescriptionUploadId"
          }
        ]
      }
    }
  }
}
