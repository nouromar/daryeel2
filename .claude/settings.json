{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(flutter analyze:*)",
      "Bash(flutter test:*)",
      "Bash(flutter pub get:*)",
      "Bash(flutter pub upgrade:*)",
      "Bash(flutter pub outdated:*)",
      "Bash(flutter format:*)",
      "Bash(flutter doctor:*)",
      "Bash(dart analyze:*)",
      "Bash(dart test:*)",
      "Bash(dart format:*)",
      "Bash(dart pub get:*)",
      "Bash(dart pub upgrade:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git stash list:*)",
      "Bash(git remote -v:*)",
      "Bash(git rev-parse:*)",
      "Bash(docker compose ps:*)",
      "Bash(docker compose logs:*)",
      "Bash(docker compose config:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(wc:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(jq:*)",
      "Bash(curl http://localhost:*)",
      "Bash(pwd)",
      "Bash(tree:*)"
    ],
    "deny": [
      "Bash(flutter clean:*)",
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)"
    ]
  }
}
